  <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
  <script is:inline>
    document.addEventListener('DOMContentLoaded', () => {
      const btn = document.getElementById('downloadPdfBtn');
      if(btn) {
        btn.addEventListener('click', () => {
          btn.style.display = 'none'; // Hide button
          
          const html = document.documentElement;
          const body = document.body;
          
          // Dynamically get the exact width and height of the user's screen
          const fullWidth = Math.max(html.scrollWidth, body.scrollWidth, html.clientWidth);
          const fullHeight = Math.max(html.scrollHeight, body.scrollHeight, html.clientHeight);

          const opt = {
            margin:       0,
            filename:     'Wayon-Travel-Platform.pdf',
            image:        { type: 'jpeg', quality: 1.0 }, // Maximum image quality
            html2canvas:  { 
              scale: 2, // 2x Retina resolution for crystal clear images
              useCORS: true, 
              scrollY: 0, 
              scrollX: 0,
              windowWidth: fullWidth,
              width: fullWidth,
              height: fullHeight
            },
            jsPDF:        { 
              unit: 'px', 
              format: [fullWidth, fullHeight], 
              orientation: 'portrait',
              compress: true
            }
          };

          window.scrollTo(0,0);

          html2pdf().set(opt).from(html).save().then(() => {
            btn.style.display = 'flex'; // Restore button
          }).catch(err => {
            console.error("PDF generation failed:", err);
            btn.style.display = 'flex';
          });
        });
      }
    });
  </script>
</Layout>
